# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google Cloud service account key (secret - never commit)
harukamuy-analytics-*.json
harukamuy-indexing-*.json
client_secret_*.json
ga4-token.json
gsc-token.json
indexing-token.json

# 個人の資産データ・記事引き継ぎ（絶対に公開しない）
/private/

# 自動生成データ（検索順位レポートなど）
data/*
# ただし人気記事ランキングはトップ表示に使うのでコミットする（CIビルドで必要）
!data/popular-posts.json

# 記事用画像の元png（webpに自動変換されるためgitには入れない。logoだけ例外）
public/images/*.png
!public/images/logo.png

# インスタ用スライド（ローカル生成物。サイトのビルドには不要）
/instagram/
